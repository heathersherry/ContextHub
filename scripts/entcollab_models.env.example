# Copy this file to secrets/entcollab_models.env and fill in real values.
# Do not commit the secrets/ copy.

# Agent model endpoint. This drives EntCollabBench agents.
ENTCOLLAB_AGENT_API_KEY="sk-..."
ENTCOLLAB_AGENT_BASE_URL="https://api.openai.com/v1"

# Judge endpoint. If omitted in the local secrets file, the loader falls back
# to the agent endpoint for JUDGE_OPENAI_API_KEY/JUDGE_OPENAI_BASE_URL.
ENTCOLLAB_JUDGE_API_KEY=""
ENTCOLLAB_JUDGE_BASE_URL=""
ENTCOLLAB_JUDGE_MODELS="gpt-4o"

# Model profiles. Use:
#   source scripts/entcollab_env.sh weak
#   source scripts/entcollab_env.sh strong
ENTCOLLAB_WEAK_MODEL="gpt-4o-mini"
ENTCOLLAB_STRONG_MODEL="gpt-5"
ENTCOLLAB_SUMMARY_MODEL="gpt-4o-mini"

# Optional benchmark timeouts.
ENTCOLLAB_TASK_TIMEOUT_SECONDS="1000"
ENTCOLLAB_AGENT_HTTP_TIMEOUT_SECONDS="400"
